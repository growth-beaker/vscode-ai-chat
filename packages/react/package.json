{
  "name": "@growthbeaker/ai-chat-react",
  "version": "1.0.0",
  "type": "module",
  "description": "React components for AI chat in VS Code webviews",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/styles.css",
    "./styles/theme": "./dist/vscode-theme.css"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vscode-ai-chat/vscode-ai-chat.git",
    "directory": "packages/react"
  },
  "keywords": [
    "vscode",
    "ai",
    "chat",
    "react",
    "assistant-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.7.0",
    "@assistant-ui/react-markdown": "^0.7.21",
    "@growthbeaker/ai-chat-core": "workspace:*",
    "mermaid": "^11.13.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20",
    "react-dom": ">=18.0.0 <20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
